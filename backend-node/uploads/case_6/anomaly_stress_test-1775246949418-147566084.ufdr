<?xml version="1.0" encoding="UTF-8"?>
<!--
  SYNTHETIC UFDR — ALL-ANOMALY STRESS TEST
  File: anomaly_stress_test.ufdr
  Purpose: Contains every anomaly type the detection pipeline can find:
    - Late-night communication bursts (temporal)
    - Off-hours spikes (temporal)
    - Communication silence gaps (temporal)
    - High-frequency burst windows (temporal)
    - Hub degree anomalies (network)
    - Isolation score anomalies (network)
    - Bridge node anomalies (network)
    - Contact diversity anomalies (network)
    - Isolation Forest outliers (communication)
    - Foreign number contacts (communication)
    - Encrypted-app-only patterns (communication)
-->
<ufdr:UFDR xmlns:ufdr="http://www.forensicinstitute.org/ufdr"
           xmlns:dc="http://purl.org/dc/elements/1.1/"
           version="1.0">

  <ufdr:metadata>
    <dc:title>Anomaly Stress Test — Full Spectrum Forensic Dataset</dc:title>
    <dc:creator>CIU Digital Forensics Lab — Testing Unit</dc:creator>
    <dc:description>Synthetic dataset designed to trigger every anomaly detection algorithm. Contains temporal spikes, silence gaps, late-night bursts, network hub outliers, isolated nodes, bridge contacts, foreign communications, and isolation forest outliers across multiple suspects.</dc:description>
    <dc:date>2025-02-01T00:00:00Z</dc:date>
    <ufdr:caseNumber>CIU-TEST-ANOMALY-001</ufdr:caseNumber>
    <ufdr:investigator>IO Test Engineer</ufdr:investigator>
    <ufdr:extractionTool>Cellebrite UFED 7.60</ufdr:extractionTool>
  </ufdr:metadata>

