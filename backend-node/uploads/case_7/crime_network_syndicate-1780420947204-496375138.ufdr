  <ufdr:metadata>
    <dc:title>Operation ShadowRing — Criminal Network Communication Intercept</dc:title>
    <dc:creator>CIU Digital Forensics Lab — Unit 7</dc:creator>
    <dc:description>Extraction from 6 seized mobile devices belonging to suspects in an ongoing narcotics trafficking and money laundering investigation. Devices show coordinated encrypted communication, off-hours coordination meetings, crypto wallet transactions, and foreign handler contacts.</dc:description>
    <dc:date>2025-03-15T08:00:00Z</dc:date>
    <ufdr:caseNumber>CIU-2025-0078</ufdr:caseNumber>
    <ufdr:investigator>IO Priya Sharma</ufdr:investigator>
    <ufdr:extractionTool>Cellebrite UFED 7.60 / MSAB XRY 10.1</ufdr:extractionTool>
    <ufdr:classification>RESTRICTED — LAW ENFORCEMENT ONLY</ufdr:classification>
  </ufdr:metadata>

