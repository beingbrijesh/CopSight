# Server Configuration
NODE_ENV=development
PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ufdr_db
DB_USER=ufdr_user
DB_PASSWORD=ufdr_password

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ufdr_password

# ChromaDB Configuration
CHROMADB_URL=http://localhost:8000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE_HOURS=24

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Service URLs
PARSER_SERVICE_URL=http://localhost:8001
SEARCH_SERVICE_URL=http://localhost:8003
GRAPH_SERVICE_URL=http://localhost:8004

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# Report Configuration
REPORT_DIR=./reports
REPORT_SIGNATURE_KEY=your-report-signing-key

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
